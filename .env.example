# ============================================================
# ORO 9 Environment Variables — EXAMPLE (no real secrets)
# Copy to .env and fill in real values
# NEVER commit the .env file itself
# ============================================================

# ── Database ─────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME"

# ── NextAuth ─────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=your_64_hex_chars_here
# Set to your production domain on Vercel:
NEXTAUTH_URL="https://your-domain.vercel.app"

# ── Email (Gmail App Password) ───────────────────────────────
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# ── AWS S3 (document storage) ────────────────────────────────
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=us-east-2
AWS_S3_BUCKET=your-bucket-name

# ── Twilio SMS ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Encryption (32 bytes = 64 hex chars) ─────────────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your_64_hex_chars_here

# ── Security ─────────────────────────────────────────────────
# Binds sessions to client IP — set false for dev if behind proxy
STRICT_IP_BINDING=true

# ── UPC Barcode Lookup ───────────────────────────────────────
UPCITEMDB_API_KEY=your_upcitemdb_key

# ── JWT (internal token signing) ────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=your_64_hex_chars_here
