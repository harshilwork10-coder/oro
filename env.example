# Database System (PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/aura_db"

# Next Auth (Security)
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-secure-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Application Settings
NODE_ENV="production"
NEXT_PUBLIC_APP_URL="https://your-domain.com"
ENCRYPTION_KEY="change-me-to-at-least-32-char-random-string"
STRICT_IP_BINDING="true"

# Email Service (Resend or Gmail)
RESEND_API_KEY=""
GMAIL_USER=""
GMAIL_APP_PASSWORD=""

# Push Notifications (VAPID)
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_EMAIL="admin@yourdomain.com"

# AWS S3 (File Storage)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""
AWS_REGION="us-east-1"

# SMS & MFA (Twilio)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# External Integrations
TAXJAR_API_KEY=""
UPCITEMDB_API_KEY=""
INTERNAL_WEBHOOK_SECRET="change-me-internal-secret"
CRON_SECRET="change-me-cron-secret"
