  gameName    String
  gameNumber  String // State game number
  ticketPrice Decimal
  prizePool   Decimal?
  isActive    Boolean  @default(true)

  packs LotteryPack[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([franchiseId])
}

model LotteryPack {
  id         String      @id @default(cuid())
  gameId     String
  game       LotteryGame @relation(fields: [gameId], references: [id])
  locationId String
  location   Location    @relation(fields: [locationId], references: [id], onDelete: Cascade)

  packNumber  String // Pack/book number
  ticketCount Int // Total tickets in pack
  soldCount   Int    @default(0)
  status      String @default("INVENTORY") // INVENTORY, ACTIVATED, SETTLED

  activatedAt DateTime?
  settledAt   DateTime?

  transactions LotteryTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([gameId, packNumber])
  @@index([locationId])
  @@index([status])
}

model LotteryTransaction {
  id          String    @id @default(cuid())
  franchiseId String
  franchise   Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  locationId  String
  location    Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)

  packId String?
  pack   LotteryPack? @relation(fields: [packId], references: [id])

  type         String // SALE, PAYOUT, CLAIM
  amount       Decimal
  ticketNumber String? // For payouts/claims

  employeeId String

  // Link to regular POS transaction if applicable
  transactionId String?

  createdAt DateTime @default(now())

  @@index([franchiseId])
  @@index([locationId])
  @@index([packId])
  @@index([createdAt])
}

// ============ TOBACCO SCAN DATA & REBATES ============

// ============ TOBACCO SCAN DEAL ENGINE ============
// Dedicated system for manufacturer-funded tobacco scan-data deals.
// Separate from generic Promotion model because tobacco deals require:
//   - Per-scan event ledger (TobaccoScanEvent per unit sold)
//   - Reimbursement/claim tracking (manufacturer owes store per unit)
//   - Batch export to ALTRIA/RJR/ITG portals
//   - Pack/carton level awareness
//   - UPC-level matching (not product/category)

// ─── Deal Definition ──────────────────────────────────────────────
model TobaccoScanDeal {
  id          String    @id @default(cuid())
  franchiseId String
  franchise   Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)

  // Manufacturer / Program
  manufacturer String // ALTRIA, RJR, ITG, LIGGETT, SWEDISH_MATCH, etc.
  programCode  String? // Manufacturer's program code (e.g., "ALTR-2026-Q1")
  dealName     String // Human-readable: "Marlboro Gold KS $1.00 Off"

  // Deal Type
  //   BUYDOWN    = per-unit price reduction ("$1 off per pack")
  //   MULTIBUY   = qty-triggered ("Buy 2 packs, get $2 off")
  //   THRESHOLD  = volume rebate ("Buy 5+ packs/week, get $X back")
  //   MIX_MATCH  = cross-brand bundle ("1 Marlboro + 1 Copenhagen = $1 off")
  type String @default("BUYDOWN")

  // What it applies to
  appliesToLevel String @default("PACK") // PACK | CARTON | BOTH

  // Quantity Rules
  minQty              Int  @default(1) // Min units to trigger deal
  maxQty              Int? // Max units deal applies to (null = unlimited)
  customerLimitPerTxn Int? // Max times deal fires per transaction

  // Reward (customer-facing discount)
  //   FIXED_AMOUNT = $1.00 off per qualifying unit
  //   PERCENTAGE   = 10% off each qualifying unit
  //   PENNY_DEAL   = price drops to $0.01
  //   FREE_UNIT    = buy X get 1 free
  rewardType  String  @default("FIXED_AMOUNT")
  rewardValue Decimal @db.Decimal(12, 2)

  // ─── Two-Layer Discount Model ──────────────────────────────────
  // Layer 1: Base manufacturer allowance (always applied)
  baseAllowance Decimal @default(0) @db.Decimal(8, 2)
  // Layer 2: Manufacturer loyalty bonus (only when customer ID present)
  loyaltyBonus  Decimal @default(0) @db.Decimal(8, 2)

  // How layers combine when both apply:
  //   STACK     = baseAllowance + loyaltyBonus (e.g., 0.50 + 1.00 = 1.50)
  //   REPLACE   = loyaltyBonus replaces baseAllowance (e.g., 1.00)
  //   MAX_ONLY  = max(baseAllowance, loyaltyBonus) (e.g., 1.00)
  stackPolicy String @default("STACK") // STACK | REPLACE | MAX_ONLY

  // Whether normal store loyalty points/rewards can stack on top of this tobacco deal
  allowStoreLoyaltyStack Boolean @default(false)

  // Reimbursement (what manufacturer pays store back per unit)
  // Usually = rewardValue. Sometimes higher (manufacturer covers margin loss too).
  reimbursementPerUnit Decimal @default(0) @db.Decimal(12, 2)

  // Store Scope (empty = all stores)
  storeIds String[] // Location IDs. Empty = all franchise locations.

  // Schedule
  startDate DateTime
  endDate   DateTime?
  status    String    @default("ACTIVE") // DRAFT | ACTIVE | PAUSED | EXPIRED | ARCHIVED

  // Rules
  requiresScanReporting Boolean @default(true)
  stackable             Boolean @default(false)
  requiresLoyalty       Boolean @default(false) // If true, POS prompts for loyalty ID

  // Import metadata
  sourceFile      String? // PDF filename this was imported from
  manufacturerPLU String? // Manufacturer's deal PLU/code

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  eligibleUpcs TobaccoScanDealUPC[]
  scanEvents   TobaccoScanEvent[]

  @@index([franchiseId, status])
  @@index([manufacturer, status])
  @@index([startDate, endDate])
  @@index([manufacturerPLU])
}

// ─── Eligible UPC Mapping ─────────────────────────────────────────
// Separate table for UPC list so we can query/index/join efficiently.
model TobaccoScanDealUPC {
  id     String          @id @default(cuid())
  dealId String
  deal   TobaccoScanDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  upc          String // Barcode (UPC-A, EAN-13, etc.)
  productName  String? // Human label for reference: "Marlboro Gold KS Box"
  packOrCarton String  @default("PACK") // PACK | CARTON

  // Optional link to inventory product (for POS display)
  itemId String?
  item   Item?   @relation(fields: [itemId], references: [id])

  @@unique([dealId, upc])
  @@index([upc]) // Fast lookup when POS scans a barcode
  @@index([dealId])
}

// ─── Per-Scan Event Ledger (RMSC 34-Field Compatible) ─────────────
// One row per tobacco line item sold. Captures all 7 RMSC discount
// channels to generate industry-standard pipe-delimited export files.
// Immutable ledger row — created only after COMPLETED sale.
model TobaccoScanEvent {
  id String @id @default(cuid())

  // Link to deal (nullable — normal sales w/o match still create events)
  tobaccoDealId String?
  tobaccoDeal   TobaccoScanDeal? @relation(fields: [tobaccoDealId], references: [id], onDelete: Restrict)

  // Link to transaction
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Restrict)
  lineItemId    String? // TransactionLineItem ID

  // ─── Line Classification ───────────────────────────────────────
  // NORMAL_SALE | MFG_MULTIPACK | OUTLET_MULTIPACK | CO_FUNDED_MULTIPACK
  // | PROMO_UPC | VAP_SALE | JBF_SALE | COUPON_SALE | LOYALTY_OFFER
  // | RETURN | EXCHANGE
  lineType   String @default("NORMAL_SALE")
  lineNumber Int    @default(1) // RMSC field 10: Scan ID / position in txn

  // ─── Claim Eligibility ─────────────────────────────────────────
  claimEligible   Boolean @default(true)
  exclusionReason String? // PROMO_UPC_PREPRICED | RETURN_VOID | EXCHANGE_RETURN

  // ─── Location / Device / User ──────────────────────────────────
  storeId   String
  location  Location @relation(fields: [storeId], references: [id])
  stationId String?
  cashierId String?

  // ─── Sale Data ─────────────────────────────────────────────────
  soldAt         DateTime @default(now())
  upc            String // 14-digit UPC (zero-padded)
  upcDescription String? // Product description for export
  qty            Int      @default(1) // SIGNED — negative for returns
  unitOfMeasure  String   @default("PACK") // PACK|CARTON|CAN|ROLL|TIN|SLEEVE

  // ─── Flags ─────────────────────────────────────────────────────
  promoFlag  Boolean @default(false) // RMSC field 17: any promo applied
  isPromoUpc Boolean @default(false) // Discount baked into UPC ("$0.50 OFF")

  // ─── Pricing ───────────────────────────────────────────────────
  regularPrice Decimal @db.Decimal(12, 2) // Shelf price (pre-discount)
  sellingPrice Decimal @db.Decimal(12, 2) // Per-unit post-all-discounts (RMSC field 13)

  // ─── Channel 1: Outlet-Funded Multipack (store pays) ───────────
  outletMultipackFlag Boolean @default(false) // RMSC field 18
  outletMultipackQty  Int? // RMSC field 19
  outletMultipackDisc Decimal @default(0) @db.Decimal(8, 2) // RMSC field 20

  // ─── Channel 2: Account Promo ──────────────────────────────────
  acctPromoName String? // RMSC field 21
  acctDiscAmt   Decimal @default(0) @db.Decimal(8, 2) // RMSC field 22

  // ─── Channel 3: Manufacturer Discount (JBF / VAP) ──────────────
  mfgDiscAmt Decimal @default(0) @db.Decimal(8, 2) // RMSC field 23

  // ─── Channel 4: PID Coupon ─────────────────────────────────────
  pidCoupon     String? // RMSC field 24: coupon UPC barcode
  pidCouponDisc Decimal @default(0) @db.Decimal(8, 2) // RMSC field 25

  // ─── Channel 5: Manufacturer Multipack Allowance ───────────────
  mfgMultipackFlag Boolean @default(false) // RMSC field 26
  mfgMultipackQty  Int? // RMSC field 27
  mfgMultipackDisc Decimal @default(0) @db.Decimal(8, 2) // RMSC field 28
  mfgPromoDesc     String? // RMSC field 29: "RJR VAP $0.75", "JBF"

  // ─── Channel 6: Manufacturer Buydown ───────────────────────────
  mfgBuydownDesc String? // RMSC field 30: "RJR Buydown"
  mfgBuydownAmt  Decimal @default(0) @db.Decimal(8, 2) // RMSC field 31

  // ─── Channel 7: Multipack Desc + Loyalty ───────────────────────
  mfgMultipackDesc String? // RMSC field 32: "RJR MP"
  loyaltyId        String? // RMSC field 33 (HASHED before storage)
  loyaltyStatus    String  @default("NONE") // NONE | PRESENT | REQUIRED_MISSING
  offerCode        String? // RMSC field 34: offer code "10201"

  // ─── Derived Totals (for fast queries) ─────────────────────────
  baseAllowanceApplied  Decimal @default(0) @db.Decimal(8, 2) // Layer 1 amount actually applied
  loyaltyBonusApplied   Decimal @default(0) @db.Decimal(8, 2) // Layer 2 amount actually applied
  storeLoyaltyBlocked   Boolean @default(false) // True if store loyalty was suppressed
  discountApplied       Decimal @db.Decimal(12, 2) // Sum of all customer-facing discounts
  reimbursementExpected Decimal @db.Decimal(12, 2) // buydown + mfg multipack + mfg disc

  // ─── Claim Tracking ────────────────────────────────────────────
  exportBatchId String?
  exportBatch   TobaccoScanExportBatch? @relation(fields: [exportBatchId], references: [id])
  claimStatus   String                  @default("UNCLAIMED") // UNCLAIMED|EXPORTED|SUBMITTED|PAID|DENIED

  createdAt DateTime @default(now())

  @@index([tobaccoDealId, soldAt])
  @@index([transactionId])
  @@index([storeId, soldAt])
  @@index([claimStatus])
  @@index([claimEligible, claimStatus])
  @@index([exportBatchId])
  @@index([upc, soldAt])
  @@index([lineType])
}

// ─── Export Batch (Claim Tracking) ────────────────────────────────
model TobaccoScanExportBatch {
  id          String    @id @default(cuid())
  franchiseId String
  franchise   Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)

  manufacturer String // ALTRIA | RJR | ITG
  programCode  String?
  weekStart    DateTime
  weekEnd      DateTime

  // Counts
  eventCount         Int     @default(0)
  totalDiscount      Decimal @default(0) @db.Decimal(12, 2)
  totalReimbursement Decimal @default(0) @db.Decimal(12, 2)

  // Status
  status          String    @default("GENERATED") // GENERATED | SUBMITTED | ACKNOWLEDGED | PAID | REJECTED
  submittedAt     DateTime?
  paidAt          DateTime?
  paidAmount      Decimal?  @db.Decimal(12, 2)
  rejectionReason String?

  // File
  exportFileName String?
  exportFormat   String? // ALTRIA_C3M | RJR_CIRCANA | ITG_PIPE

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  events TobaccoScanEvent[]

  @@index([franchiseId, manufacturer])
  @@index([weekStart, weekEnd])
  @@index([status])
}

// ─── Manufacturer Account Config ──────────────────────────────────
model ManufacturerConfig {
  id          String    @id @default(cuid())
  franchiseId String
  franchise   Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)

  manufacturer String // ALTRIA, RJR, ITG

  // Store credentials
  storeId       String?
  accountNumber String?
  apiKey        String?
  apiSecret     String?
  portalUrl     String?

  // Rebate tracking (base scan-data rebate, separate from deal buydowns)
  rebatePerPack   Decimal @default(0.04) @db.Decimal(12, 4)
  rebatePerCarton Decimal @default(0.40) @db.Decimal(12, 4)
  loyaltyBonus    Decimal @default(0) @db.Decimal(12, 2)

  isActive   Boolean   @default(true)
  lastSyncAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([franchiseId, manufacturer])
  @@index([franchiseId])
}

// =====================================
// TAX JURISDICTION & EXCISE TAX MODELS
// =====================================
// For handling location-based sales tax + volume-based excise taxes (like Cook County liquor tax)

model TaxJurisdiction {
  id          String    @id @default(cuid())
  franchiseId String
  franchise   Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)

  name String // "Cook County", "City of Chicago", "Illinois State"
  type String // STATE, COUNTY, CITY, DISTRICT
  code String? // FIPS code or jurisdiction identifier

  // Sales Tax (percentage-based)
  salesTaxRate Decimal @default(0) @db.Decimal(7, 4) // e.g., 6.25 for 6.25%

  // Effective date for rate changes (pre-schedule future rates)
  effectiveFrom DateTime @default(now())

  // Description for display
  description String?

  isActive Boolean @default(true)

  // Order for tax calculation (lower = calculated first)
  priority Int @default(0)

  // Excise tax rules for this jurisdiction (per-unit taxes)
  exciseTaxRules ExciseTaxRule[]

  // Locations that apply this jurisdiction
  locations LocationTaxJurisdiction[]

  // Tax Groups that include this component
  taxGroupComponents TaxGroupComponent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([franchiseId, name])
  @@index([franchiseId])
}

// Excise Tax Rules - per-unit taxes based on product type/volume
model ExciseTaxRule {
  id             String          @id @default(cuid())
  jurisdictionId String
  jurisdiction   TaxJurisdiction @relation(fields: [jurisdictionId], references: [id], onDelete: Cascade)

  // Product type this rule applies to
  productType String // BEER, WINE_LIGHT, WINE_HEAVY, SPIRITS, TOBACCO_PACK, TOBACCO_CARTON

  // Tax calculation
  ratePerGallon Decimal? @db.Decimal(12, 4) // For liquids - rate per gallon (will be prorated by ml)
  ratePerUnit   Decimal? @db.Decimal(12, 4) // For non-liquids - flat rate per unit (e.g., per cigarette pack)
  ratePerOz     Decimal? @db.Decimal(12, 4) // Alternative - per ounce

  // ABV thresholds for wine classification
  minAbv Decimal? @db.Decimal(5, 2) // Minimum ABV for this rule to apply
  maxAbv Decimal? @db.Decimal(5, 2) // Maximum ABV for this rule to apply

  description String? // "Cook County Spirits Tax"
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([jurisdictionId, productType])
  @@index([jurisdictionId])
}

// Many-to-many: Which jurisdictions apply to each location
// Includes owner-friendly display names and applicability rules
model LocationTaxJurisdiction {
  id             String          @id @default(cuid())
  locationId     String
  location       Location        @relation(fields: [locationId], references: [id], onDelete: Cascade)
  jurisdictionId String
  jurisdiction   TaxJurisdiction @relation(fields: [jurisdictionId], references: [id], onDelete: Cascade)

  // Owner-friendly display name (shown on receipt/POS/reports)
  // If null, fallback to jurisdiction name or auto-generated label
  displayName String?

  // Display order on receipts (lower = first)
  priority Int @default(0)

  // Enable/disable this jurisdiction for this location
  isActive Boolean @default(true)

  // Applicability flags (what item types this tax applies to)
  appliesProducts Boolean @default(true)
  appliesServices Boolean @default(false)
  appliesFood     Boolean @default(false)
  appliesAlcohol  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([locationId, jurisdictionId])
  @@index([locationId])
  @@index([jurisdictionId])
}

// Category-level tax rules per location
// Allows different tax treatment per category per store (e.g., Food exempt in Store A, taxable in Store B)
model LocationTaxCategoryRule {
  id         String          @id @default(cuid())
  locationId String
  location   Location        @relation(fields: [locationId], references: [id], onDelete: Cascade)
  categoryId String
  category   ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  // Tax treatment for this category at this location
  taxTreatment TaxTreatment @default(TAXABLE)

  // Optional notes (e.g., "Grocery food exempt per state law")
  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([locationId, categoryId])
  @@index([locationId])
  @@index([categoryId])
}

// ============ TAX GROUPS ============
// Tax Group = named bundle of tax components per location
// E.g., ALCOHOL = State Sales + County + City + Liquor Surcharge

model TaxGroup {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation("LocationTaxGroups", fields: [locationId], references: [id], onDelete: Cascade)

  name      String // "GENERAL", "ALCOHOL", "TOBACCO", "GROCERY", "PREPARED_FOOD"
  isDefault Boolean @default(false) // One default per location (fallback)

  // Components in this group
  components TaxGroupComponent[]

  // Departments using this group as default
  departmentDefaults DepartmentTaxDefault[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([locationId, name])
  @@index([locationId])
}

// Join table: Tax Group → Tax Components (jurisdictions)
model TaxGroupComponent {
  id             String          @id @default(cuid())
  taxGroupId     String
  taxGroup       TaxGroup        @relation(fields: [taxGroupId], references: [id], onDelete: Cascade)
  jurisdictionId String
  jurisdiction   TaxJurisdiction @relation(fields: [jurisdictionId], references: [id], onDelete: Cascade)

  // 0 = non-compound (parallel with others), 1+ = compound order
  compoundOrder Int @default(0)

  @@unique([taxGroupId, jurisdictionId])
  @@index([taxGroupId])
  @@index([jurisdictionId])
}

// Department → Tax Group default mapping per location
// All products in a department inherit this Tax Group automatically
model DepartmentTaxDefault {
  id         String          @id @default(cuid())
  locationId String
  location   Location        @relation("LocationDeptTaxDefaults", fields: [locationId], references: [id], onDelete: Cascade)
  categoryId String
  category   ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  taxGroupId String
  taxGroup   TaxGroup        @relation(fields: [taxGroupId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([locationId, categoryId])
  @@index([locationId])
  @@index([categoryId])
  @@index([taxGroupId])
}

// ============ PRICE CHANGE AUDIT LOG ============

model PriceChangeLog {
  id String @id @default(cuid())

  // Supports both Item and Product (one or the other)
  itemId    String?
  item      Item?    @relation(fields: [itemId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  oldPrice Decimal  @db.Decimal(12, 2)
  newPrice Decimal  @db.Decimal(12, 2)
  oldCost  Decimal? @db.Decimal(12, 2)
  newCost  Decimal? @db.Decimal(12, 2)

  reason        String? // "Cost update", "Manual override", "Import", "Auto-reprice"
  source        String  @default("MANUAL") // MANUAL, AUTO_REPRICE, IMPORT, PROMO, VENDOR_UPDATE
  changedBy     String // User ID
  changedByName String? // User name for display

  createdAt DateTime @default(now())

  @@index([itemId])
  @@index([productId])
  @@index([changedBy])
  @@index([createdAt])
}

// ============ PRICING RULES ============
// Department-level auto-pricing: cost → sell price calculation

model PricingRule {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  name  String // "BEER_PACKS", "SPIRITS", "TOBACCO_CIG", etc.
  label String // "Beer Packs (6/12/24)", human-friendly

  // Method: MARKUP or TARGET_MARGIN
  method String @default("MARKUP")

  // JSON config: { tiers, rounding, caps, lockIfMsrpPresent, managerOverrideOnly }
  config Json

  isActive Boolean @default(true)

  // Categories using this rule
  categoryRules CategoryPricingRule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([locationId, name])
  @@index([locationId])
}

// Category → Pricing Rule mapping per location
model CategoryPricingRule {
  id            String          @id @default(cuid())
  locationId    String
  location      Location        @relation("LocationCatPricingRules", fields: [locationId], references: [id], onDelete: Cascade)
  categoryId    String
  category      UnifiedCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  pricingRuleId String
  pricingRule   PricingRule     @relation(fields: [pricingRuleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([locationId, categoryId])
  @@index([locationId])
  @@index([categoryId])
  @@index([pricingRuleId])
}

// ============ STORE ACCOUNT (A/R) TRACKING ============
// Tracks all charges and payments to customer store accounts

model StoreAccountTransaction {
  id          String @id @default(cuid())
  clientId    String
  client      Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  franchiseId String

  // Transaction Type
  type String // CHARGE = customer bought on account, PAYMENT = customer paid down balance

  // Amounts
  amount       Decimal // Positive for CHARGE, positive for PAYMENT
  balanceAfter Decimal // Running balance after this transaction

  // References
  transactionId String? // Link to the POS transaction (for CHARGE)
  invoiceNumber String? // Invoice reference

  // Payment Details (for PAYMENT type)
  paymentMethod String? // CASH, CHECK, CARD
  checkNumber   String? // If paid by check

  // Notes
  note String?

  // Who processed this
  employeeId   String
  employeeName String?

  createdAt DateTime @default(now())

  @@index([clientId])
  @@index([franchiseId])
  @@index([type])
  @@index([createdAt])
}

// ============ MULTI-STORE OPERATIONS ============

// Inventory Transfer between stores
model InventoryTransfer {
  id             String @id @default(cuid())
  transferNumber String @unique // TR-001, TR-002, etc.

  // From/To Locations
  fromLocationId String
  fromLocation   Location @relation("TransfersFrom", fields: [fromLocationId], references: [id])
  toLocationId   String
  toLocation     Location @relation("TransfersTo", fields: [toLocationId], references: [id])

  // Status: PENDING, APPROVED, IN_TRANSIT, RECEIVED, DISCREPANCY, CANCELLED
  status String @default("PENDING")

  // Reason/Notes
  reason String? // "Stock Balance", "Emergency Request", etc.
  notes  String?

  // Workflow tracking
  requestedById   String
  requestedByName String?
  approvedById    String?
  approvedByName  String?
  shippedById     String?
  shippedByName   String?
  receivedById    String?
  receivedByName  String?

  // Timestamps
  requestedAt DateTime  @default(now())
  approvedAt  DateTime?
  shippedAt   DateTime?
  receivedAt  DateTime?

  // Value tracking
  totalItems Int     @default(0)
  totalValue Decimal @default(0)

  // Items
  items TransferItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([status])
}

model TransferItem {
  id         String            @id @default(cuid())
  transferId String
  transfer   InventoryTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  // Product reference
  itemId      String
  item        Item    @relation(fields: [itemId], references: [id])
  itemName    String // Snapshot for history
  itemSku     String?
  itemBarcode String?

  // Quantities
  quantitySent     Int
  quantityReceived Int? // Null until received

  // Cost tracking
  unitCost Decimal @default(0)

  // Discrepancy
  discrepancyNote String?

  @@index([transferId])
  @@index([itemId])
}

// Cash Drawer Count (shift open/close or mid-shift)
model CashCount {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  // Type: OPEN, MID_SHIFT, CLOSE
  type String

  // Employee
  employeeId   String
  employeeName String?

  // Amounts
  expectedCash Decimal @default(0)
  countedCash  Decimal
  variance     Decimal @default(0) // countedCash - expectedCash

  // Denomination breakdown (JSON)
  denominations String? // JSON: {"100": 2, "50": 1, "20": 5, ...}

  // Notes
  note String?

  // Approval (if variance is high)
  approvedById   String?
  approvedByName String?
  approvedAt     DateTime?

  createdAt DateTime @default(now())

  @@index([locationId])
  @@index([employeeId])
  @@index([type])
  @@index([createdAt])
}

// Safe Drop (drawer to safe)
model SafeDrop {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  // Employee
  employeeId   String
  employeeName String?

  // Amount
  amount Decimal

  // Verification (witnessed by manager)
  witnessedById   String?
  witnessedByName String?

  createdAt DateTime @default(now())

  @@index([locationId])
  @@index([createdAt])
}

// Bank Deposit Log
model DepositLog {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  // Expected vs Actual
  expectedAmount  Decimal
  depositedAmount Decimal
  variance        Decimal @default(0)

  // Bank details
  bankDate     DateTime
  slipNumber   String?
  slipImageUrl String?

  // Status: PENDING, DEPOSITED, RECONCILED, DISCREPANCY
  status String @default("PENDING")

  // Who logged/reconciled
  loggedById       String?
  loggedByName     String?
  reconciledById   String?
  reconciledByName String?
  reconciledAt     DateTime?

  note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId])
  @@index([status])
  @@index([bankDate])
}

// Audit Events (for Loss Prevention)
model AuditEvent {
  id String @id @default(cuid())

  // Where
  locationId  String
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  franchiseId String

  // Who
  employeeId   String?
  employeeName String?

  // What type: VOID, REFUND, PRICE_OVERRIDE, NO_SALE, LINE_DELETE, 
  //            ID_OVERRIDE, RETURN_NO_RECEIPT, MANUAL_DISCOUNT, 
  //            PRICE_CHANGE, COST_CHANGE, DRAWER_OPEN
  eventType String

  // Severity: LOW, MEDIUM, HIGH
  severity String @default("LOW")

  // Details (JSON)
  details String? // JSON with event-specific data

  // Financial impact
  amount Decimal?

  // Related transaction
  transactionId String?

  // Reviewed/Acknowledged
  reviewedById   String?
  reviewedByName String?
  reviewedAt     DateTime?
  reviewNote     String?

  createdAt DateTime @default(now())

  @@index([locationId])
  @@index([franchiseId])
  @@index([employeeId])
  @@index([eventType])
  @@index([severity])
  @@index([createdAt])
}

// Store Exceptions (Aggregated alerts for owner dashboard)
model StoreException {
  id String @id @default(cuid())

  // Where
  locationId  String
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  franchiseId String

  // Type: LOW_STOCK, CASH_VARIANCE, VOID_SPIKE, REFUND_SPIKE, 
  //       DEPOSIT_OVERDUE, TRANSFER_DISCREPANCY, OFFLINE, DEVICE_ERROR
  exceptionType String

  // Severity: INFO, WARNING, CRITICAL
  severity String @default("WARNING")

  // Title and details
  title       String
  description String?

  // Status: ACTIVE, ACKNOWLEDGED, RESOLVED
  status String @default("ACTIVE")

  // Actions taken
  acknowledgedById   String?
  acknowledgedByName String?
  acknowledgedAt     DateTime?
  resolvedById       String?
  resolvedByName     String?
  resolvedAt         DateTime?
  resolutionNote     String?

  // Related entity
  relatedEntityType String? // TRANSFER, DEPOSIT, EMPLOYEE, PRODUCT
  relatedEntityId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId])
  @@index([franchiseId])
  @@index([exceptionType])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
}

// ============ LOCATION PAYMENT PROFILE (CRITICAL NEW) ============
// MID/TID per location - replaces legacy fields on Location

model LocationPaymentProfile {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  processorName String? // DATAWIRE, TSYS, VANTIV, WORLDPAY, FIRST_DATA
  processorMID  String? // Merchant ID from processor
  processorTID  String? // Terminal ID from processor
  gateway       String? // Gateway name

  // Surcharge configuration
  surchargeType  String? // PERCENT, FIXED, NONE
  surchargeValue Decimal? // Percentage or fixed amount

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId])
  @@index([processorMID])
  @@index([processorTID])
}

// ============ LOCATION ITEM OVERRIDE (CRITICAL NEW) ============
// Price/availability per store - THE KEY TO MULTI-STORE

model LocationItemOverride {
  id          String    @id @default(cuid())
  locationId  String
  location    Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)
  franchiseId String
  franchise   Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)

  // Exactly ONE of these must be set (Item OR Product OR Service)
  itemId    String?
  item      Item?    @relation(fields: [itemId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  // Overrides (null = inherit from parent)
  priceOverride    Decimal? // Override price for this location
  isActiveOverride Boolean? // Override availability (null=inherit, false=off, true=on)
  taxGroupOverride String? // Override tax group

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([locationId, itemId])
  @@unique([locationId, productId])
  @@unique([locationId, serviceId])
  @@index([locationId])
  @@index([franchiseId])
}

// ============ STOCK ON HAND (CRITICAL NEW) ============
// Inventory per location per item - replaces global Product.stock

model StockOnHand {
  id          String    @id @default(cuid())
  locationId  String
  location    Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)
  franchiseId String
  franchise   Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)

  // Item reference
  itemId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  qtyOnHand    Decimal @default(0)
  reorderPoint Int? // Alert when stock <= this

  updatedAt DateTime @updatedAt

  @@unique([locationId, itemId])
  @@index([locationId])
  @@index([itemId])
}

// ============ OPS: CLIENT CARD (NEW) ============
// Location health/config status for support

model ClientCard {
  id         String   @id @default(cuid())
  locationId String   @unique
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  posType    String? // POS software type
  posVersion String? // POS software version
  dbType     String? // Database type

  healthJson   String? // JSON health status data
  lastHealthAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============ OPS: TICKET (NEW) ============
// Support ticket system

model Ticket {
  id       String @id @default(cuid())
  publicId String @unique @default(cuid())

  franchiseId String
  franchise   Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  locationId  String
  location    Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)

  createdByUserId  String?
  createdByUser    User?   @relation("TicketCreator", fields: [createdByUserId], references: [id])
  assignedToUserId String?
  assignedToUser   User?   @relation("TicketAssignee", fields: [assignedToUserId], references: [id])

  severity String // P0, P1, P2, P3, P4
  status   String  @default("OPEN") // OPEN, PENDING, RESOLVED, CLOSED
  category String?
  subject  String

  slaDueAt DateTime?

  messages TicketMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, severity])
  @@index([locationId])
  @@index([franchiseId])
  @@index([assignedToUserId])
}

// ============ OPS: TICKET MESSAGE (NEW) ============

model TicketMessage {
  id       String @id @default(cuid())
  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  authorUserId String?
  authorUser   User?   @relation("TicketMessageAuthor", fields: [authorUserId], references: [id])

  isInternal Boolean @default(false) // Internal note vs customer-visible
  message    String

  createdAt DateTime @default(now())

  @@index([ticketId])
}

// ============ OPS: INCIDENT (NEW) ============
// System-wide incidents

model Incident {
  id       String @id @default(cuid())
  publicId String @unique @default(cuid())

  title  String
  status String @default("INVESTIGATING") // INVESTIGATING, MONITORING, RESOLVED

  impacts IncidentImpact[]

  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([status])
}

// ============ OPS: INCIDENT IMPACT (NEW) ============

model IncidentImpact {
  id         String   @id @default(cuid())
  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  // ONE of these must be set
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id])
  terminalId String?
  terminal   Terminal? @relation(fields: [terminalId], references: [id])

  createdAt DateTime @default(now())

  @@index([incidentId])
}

// ============ OPS: DOCUMENT (NEW) ============
// Onboarding documents

model Document {
  id          String    @id @default(cuid())
  franchiseId String
  franchise   Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  locationId  String?
  location    Location? @relation(fields: [locationId], references: [id])

  docType  String // MPA, VOID_CHECK, SS4, DL, FEIN_LETTER, OTHER
  fileName String
  fileUrl  String
  status   String @default("UPLOADED") // UPLOADED, VERIFIED, REJECTED

  createdAt DateTime @default(now())

  @@index([franchiseId, docType])
  @@index([locationId])
}

// ============ ONBOARDING REQUEST (NEW) ============
// Franchisor submits → Provider processes

model OnboardingRequest {
  id            String @id @default(cuid())
  requestNumber String @unique // e.g. ORX-ONB-20251224-000123
  requestType   Int // 1=NEW_FRANCHISEE, 2=ADD_LOCATION, 3=DEVICE_CHANGE
  status        Int    @default(1) // 1=SUBMITTED,2=IN_REVIEW,3=WAITING_DOCS,4=APPROVED,5=SHIPPED,6=ACTIVE,7=REJECTED

  franchisorId     String?
  franchisor       Franchisor? @relation(fields: [franchisorId], references: [id], onDelete: Cascade)
  franchiseId      String?
  franchise        Franchise?  @relation("OnboardingRequests", fields: [franchiseId], references: [id])
  createdByUserId  String
  createdByUser    User        @relation("CreatedOnboardingRequests", fields: [createdByUserId], references: [id])
  assignedToUserId String?
  assignedToUser   User?       @relation("AssignedOnboardingRequests", fields: [assignedToUserId], references: [id])

  businessType Int // 1=RETAIL, 2=SALON, 3=BOTH

  // Dealer association — captured at onboarding time
  // Links the new client to the dealer/reseller that referred them
  dealerBrandingId String?
  dealerBranding   DealerBranding? @relation(fields: [dealerBrandingId], references: [id])

  contactName  String?
  contactEmail String?
  contactPhone String?

  notes         String? // Visible notes
  internalNotes String? // Provider only

  submittedAt    DateTime  @default(now())
  lastStatusAt   DateTime  @default(now())
  approvedAt     DateTime?
  rejectedAt     DateTime?
  rejectedReason String?
  activatedAt    DateTime?

  // Relations
  locations OnboardingRequestLocation[]
  devices   OnboardingRequestDevice[]
  documents OnboardingRequestDocument[]
  shipments Shipment[]
  events    OnboardingRequestEvent[]

  @@index([status, submittedAt])
  @@index([assignedToUserId, status])
  @@index([franchisorId, status])
  @@index([franchiseId])
  @@index([dealerBrandingId])
}

// ============ ONBOARDING REQUEST LOCATION (NEW) ============
// Requested locations (pre-creation)

model OnboardingRequestLocation {
  id                  String            @id @default(cuid())
  onboardingRequestId String
  onboardingRequest   OnboardingRequest @relation(fields: [onboardingRequestId], references: [id], onDelete: Cascade)

  franchiseId String?
  franchise   Franchise? @relation("OnboardingLocations", fields: [franchiseId], references: [id])
  locationId  String?
  location    Location?  @relation("OnboardingLocations", fields: [locationId], references: [id])

  locationName String
  phone        String?

  address1   String
  address2   String?
  city       String
  state      String
  postalCode String
  country    String  @default("USA")

  requestedTerminals Int @default(0)
  requestedStations  Int @default(0)

  notes     String?
  createdAt DateTime @default(now())

  // Relations
  devices   OnboardingRequestDevice[]
  documents OnboardingRequestDocument[]

  @@index([onboardingRequestId])
  @@index([locationId])
}

// ============ ONBOARDING REQUEST DEVICE (NEW) ============
// Devices reserved/assigned for request

model OnboardingRequestDevice {
  id                  String                     @id @default(cuid())
  onboardingRequestId String
  onboardingRequest   OnboardingRequest          @relation(fields: [onboardingRequestId], references: [id], onDelete: Cascade)
  requestLocationId   String?
  requestLocation     OnboardingRequestLocation? @relation(fields: [requestLocationId], references: [id])

  locationId String?
  location   Location? @relation("OnboardingDevices", fields: [locationId], references: [id])
  terminalId String?
  terminal   Terminal? @relation("OnboardingDevices", fields: [terminalId], references: [id])

  deviceType       Int // 1=PAYMENT_TERMINAL, 2=STATION_REGISTER, 3=OTHER
  model            String?
  serialNumber     String?
  ipAddress        String?
  port             Int?
  assignmentStatus Int       @default(1) // 1=RESERVED, 2=ASSIGNED, 3=REMOVED
  assignedAt       DateTime?

  notes     String?
  createdAt DateTime @default(now())

  @@index([onboardingRequestId, assignmentStatus])
  @@index([terminalId])
}

// ============ ONBOARDING REQUEST DOCUMENT (NEW) ============
// Docs collected for onboarding

model OnboardingRequestDocument {
  id                  String                     @id @default(cuid())
  onboardingRequestId String
  onboardingRequest   OnboardingRequest          @relation(fields: [onboardingRequestId], references: [id], onDelete: Cascade)
  requestLocationId   String?
  requestLocation     OnboardingRequestLocation? @relation(fields: [requestLocationId], references: [id])

  docType Int // 1=DL, 2=SS4_FEIN, 3=VOID_CHECK, 4=LEASE, 5=OTHER
  status  Int @default(1) // 1=MISSING, 2=UPLOADED, 3=VERIFIED, 4=REJECTED

  fileName         String?
  contentType      String?
  fileUrl          String?
  uploadedByUserId String?
  uploadedByUser   User?     @relation("UploadedOnboardingDocs", fields: [uploadedByUserId], references: [id])
  uploadedAt       DateTime?

  verifiedByUserId String?
  verifiedByUser   User?     @relation("VerifiedOnboardingDocs", fields: [verifiedByUserId], references: [id])
  verifiedAt       DateTime?
  rejectReason     String?

  notes     String?
  createdAt DateTime @default(now())

  @@index([onboardingRequestId, status])
}

// ============ SHIPMENT (NEW) ============
// Shipping header

model Shipment {
  id                  String             @id @default(cuid())
  onboardingRequestId String?
  onboardingRequest   OnboardingRequest? @relation(fields: [onboardingRequestId], references: [id])
  franchiseId         String?
  franchise           Franchise?         @relation("Shipments", fields: [franchiseId], references: [id])
  locationId          String?
  location            Location?          @relation("Shipments", fields: [locationId], references: [id])

  status         Int     @default(1) // 1=DRAFT, 2=READY, 3=SHIPPED, 4=DELIVERED, 5=CANCELLED
  carrier        String? // UPS, FedEx, USPS, Other
  serviceLevel   String?
  trackingNumber String?

  shipToName       String?
  shipToPhone      String?
  shipToAddress1   String
  shipToAddress2   String?
  shipToCity       String
  shipToState      String
  shipToPostalCode String
  shipToCountry    String  @default("USA")

  notes String?

  createdByUserId String
  createdByUser   User      @relation("CreatedShipments", fields: [createdByUserId], references: [id])
  createdAt       DateTime  @default(now())
  shippedAt       DateTime?
  deliveredAt     DateTime?

  // Relations
  packages ShipmentPackage[]
  items    ShipmentItem[]

  @@index([onboardingRequestId, status])
  @@index([trackingNumber])
  @@index([locationId, status])
}

// ============ SHIPMENT PACKAGE (NEW) ============
// Multi-box shipments

model ShipmentPackage {
  id         String   @id @default(cuid())
  shipmentId String
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  packageNo Int
  weightLb  Float?
  lengthIn  Float?
  widthIn   Float?
  heightIn  Float?

  createdAt DateTime @default(now())

  // Relations
  items ShipmentItem[]

  @@unique([shipmentId, packageNo])
  @@index([shipmentId])
}

// ============ SHIPMENT ITEM (NEW) ============
// What's inside each package

model ShipmentItem {
  id         String           @id @default(cuid())
  shipmentId String
  shipment   Shipment         @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  packageId  String?
  package    ShipmentPackage? @relation(fields: [packageId], references: [id])

  itemType     Int // 1=TERMINAL, 2=STATION, 3=ACCESSORY, 4=OTHER
  terminalId   String?
  terminal     Terminal? @relation("ShippedTerminals", fields: [terminalId], references: [id])
  serialNumber String?

  sku      String?
  itemName String
  qty      Int     @default(1)

  createdAt DateTime @default(now())

  @@index([shipmentId])
  @@index([terminalId])
}

// ============ ONBOARDING REQUEST EVENT (NEW) ============
// Timeline/audit feed

model OnboardingRequestEvent {
  id                  String            @id @default(cuid())
  onboardingRequestId String
  onboardingRequest   OnboardingRequest @relation(fields: [onboardingRequestId], references: [id], onDelete: Cascade)

  eventType   Int // 1=STATUS_CHANGE, 2=NOTE, 3=DOC_REQUEST, 4=DOC_UPLOADED, 5=DOC_VERIFIED, 6=DEVICE_ASSIGNED, 7=SHIPMENT_CREATED, 8=ACTIVATED
  message     String?
  actorUserId String?
  actorUser   User?   @relation("OnboardingEventActor", fields: [actorUserId], references: [id])

  createdAt DateTime @default(now())

  @@index([onboardingRequestId, createdAt])
}

// ============ ORDER TEMPLATES (SMART ORDERING) ============
// Saved order templates for one-click reordering

model OrderTemplate {
  id          String    @id @default(cuid())
  franchiseId String
  franchise   Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)

  name       String // "Weekly Beverage Order", "Monthly Tobacco"
  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])
  isDefault  Boolean   @default(false)

  // Usage tracking
  usageCount Int       @default(0)
  lastUsedAt DateTime?

  items OrderTemplateItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([franchiseId])
}

model OrderTemplateItem {
  id         String        @id @default(cuid())
  templateId String
  template   OrderTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  productId  String
  product    Product @relation(fields: [productId], references: [id])
  defaultQty Int     @default(1)

  @@index([templateId])
}

// ============ CASH PAYOUTS ============
// Track all cash payouts from drawer (lottery, scratch-offs, vendor payments)

model CashPayout {
  id          String             @id @default(cuid())
  franchiseId String
  franchise   Franchise          @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  locationId  String?
  location    Location?          @relation(fields: [locationId], references: [id])
  userId      String
  user        User               @relation(fields: [userId], references: [id])
  sessionId   String?
  session     CashDrawerSession? @relation(fields: [sessionId], references: [id])

  amount Decimal // Payout amount
  type   String // 'lottery', 'scratch', 'vendor'

  // For lottery/scratch payouts
  ticketNumber String?

  // For vendor payouts  
  vendorName    String?
  invoiceNumber String?

  notes String?

  createdAt DateTime @default(now())

  @@index([franchiseId])
  @@index([type])
  @@index([createdAt])
}

// Scratch ticket barcode to price mapping
// Set once in Lottery Management, looked up at POS for quick sales
model ScratchTicket {
  id          String    @id @default(cuid())
  franchiseId String
  franchise   Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)

  barcode String // Ticket barcode (scanned)
  price   Decimal // Ticket price
  name    String? // Optional game name

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([franchiseId, barcode])
  @@index([franchiseId])
  @@index([barcode])
}

// ============ NOTIFICATIONS ============
// In-app notifications for owners/managers
// Types: LOW_INVENTORY, SHIFT_STARTED, SHIFT_ENDED, LARGE_REFUND, DAILY_SUMMARY, STORE_OFFLINE
model Notification {
  id          String     @id @default(cuid())
  franchiseId String?
  franchise   Franchise? @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  userId      String? // Target user (null = broadcast to all franchise users)
  user        User?      @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    String // LOW_INVENTORY, SHIFT_STARTED, etc.
  title   String
  message String
  data    String? // JSON data for deep linking

  isRead Boolean   @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([franchiseId])
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// ============ MASTER UPC DATABASE ============
// Global product catalog from UPCitemdb.com - shared across ALL stores
// Lookup once, store forever - saves API calls
model MasterUpcProduct {
  id  String @id @default(cuid())
  upc String @unique // The UPC/EAN barcode

  // Product Info
  name        String
  brand       String?
  description String?
  category    String?

  // Sizing
  size   String?
  weight String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([upc])
  @@index([brand])
  @@index([category])
}

// ============ PRINTER CONFIGURATION ============
// Configure printers per store with type routing (receipt, kitchen, bar, label)
model PrinterConfig {
  id          String    @id @default(cuid())
  franchiseId String
  franchise   Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)

  name        String // "Register 1 Receipt", "Kitchen", "Bar", "Label Printer"
  type        String // RECEIPT, KITCHEN, BAR, LABEL
  printerLang String @default("ESCPOS") // ESCPOS, ZPL
  agentUrl    String // "http://localhost:9100" or "http://192.168.1.50:9100"

  isDefault Boolean @default(false) // Default printer for this type
  isActive  Boolean @default(true)

  // For identification
  stationId  String? // Which register this belongs to
  macAddress String? // For network printers

  // Label printer settings (Zebra)
  labelWidth String? // "2x1", "1.5x1", "1x1"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([franchiseId])
  @@index([type])
}

// ============ WEB PUSH NOTIFICATIONS ============

model PushSubscription {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  endpoint String @unique // Push service endpoint URL
  p256dh   String // Browser key for encryption
  auth     String // Auth secret for encryption

  // Device info for management
  userAgent  String? // Browser/OS info
  deviceName String? // "iPhone", "Chrome on Windows"

  createdAt DateTime @default(now())

  @@index([userId])
}

// ============ LOCATION-SPECIFIC PRICING ============
// Allows multi-store owners and franchisees to set different prices per location
// If no LocationProduct exists, falls back to Product.price (franchise default)

// @deprecated — LocationProduct model REMOVED.
// Relations were already commented out (dead model).
// Superseded by: LocationItemOverride (per-location pricing) + StockOnHand (per-location stock).
// If you need per-location product data, use LocationItemOverride or StockOnHand.

// ============ ID SCAN LOGGING ============
// Track age verification scans and overrides

model IDScanLog {
  id          String @id @default(cuid())
  locationId  String
  franchiseId String

  transactionId String?
  employeeId    String?
  employeeName  String?

  type        String // SCANNED, OVERRIDE
  customerDOB DateTime?
  items       String? // JSON list of age-restricted items

  createdAt DateTime @default(now())

  @@index([locationId])
  @@index([franchiseId])
  @@index([createdAt])
}

// ============ IDEMPOTENCY SUPPORT ============

model IdempotencyKey {
  id          String   @id @default(cuid())
  key         String
  franchiseId String
  response    String?
  createdAt   DateTime @default(now())

  @@unique([key, franchiseId])
  @@index([createdAt])
}

// ============ SALON: TIME BLOCKING ============
// Staff can block personal time (lunch, vacation, appointments outside system)

model TimeBlock {
  id         String  @id @default(cuid())
  userId     String
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  locationId String?

  title     String? // "Lunch Break", "Vacation", "Personal"
  startTime DateTime
  endTime   DateTime

  // Recurring blocks (every Monday 12-1pm)
  isRecurring    Boolean   @default(false)
  recurringDays  String? // JSON: ["MON", "TUE"] or null for one-time
  recurringUntil DateTime? // Optional end date for recurring

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([startTime])
}

// ============ SALON: BOOTH RENTAL ============
// Track chair/booth renters and their payments

model BoothRental {
  id          String  @id @default(cuid())
  franchiseId String
  locationId  String?
  userId      String // The barber/stylist renting

  boothNumber String? // "Chair 3", "Station B"
  weeklyRate  Float   @default(0)
  dueDay      Int     @default(1) // Day of week (0=Sun, 1=Mon, etc.)

  startDate DateTime  @default(now())
  endDate   DateTime? // If they leave

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([franchiseId])
  @@index([userId])
}

// ============ SALON: COMPREHENSIVE COMPENSATION SYSTEM ============
// For MULTI_LOCATION_OWNER: Chair rental, hourly, salary, commission
// Supports history via effective dates, multi-location, proper commission math

model CompensationPlan {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  locationId String? // null = applies everywhere
  location   Location? @relation("CompensationPlans", fields: [locationId], references: [id])

  // Worker classification (legal/tax purposes)
  workerType String @default("W2_EMPLOYEE") // W2_EMPLOYEE, 1099_CONTRACTOR, BOOTH_RENTER

  // Compensation type
  compensationType String // CHAIR_RENTAL, HOURLY, SALARY, COMMISSION, HYBRID

  // Effective dates (enables history)
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime? // null = currently active

  // Hourly
  hourlyRate Decimal? @db.Decimal(10, 2)

  // Salary
  salaryAmount Decimal? @db.Decimal(10, 2)
  salaryPeriod String? // WEEKLY, BIWEEKLY, MONTHLY

  // Commission (Decimal for 67.5% etc)
  commissionSplit        Decimal? @db.Decimal(5, 2) // Employee's % (70.00 = employee gets 70%)
  commissionBase         String   @default("AFTER_DISCOUNT") // ORIGINAL_PRICE, AFTER_DISCOUNT
  commissionAppliesTo    String   @default("SERVICES_ONLY") // SERVICES_ONLY, SERVICES_AND_PRODUCTS
  commissionIncludesTax  Boolean  @default(false)
  commissionIncludesTips Boolean  @default(false)

  // Chair/Booth Rental
  chairRentAmount     Decimal?  @db.Decimal(10, 2)
  chairRentPeriod     String? // WEEKLY, MONTHLY
  chairRentDueDay     Int? // 1-31 for monthly, 1-7 for weekly
  chairRentStartDate  DateTime?
  chairRentAutoDeduct Boolean   @default(false) // Deduct from payout?

  // Time tracking (separate from pay model)
  requiresTimeClock Boolean @default(false)

  // Price control (separate from compensation type)
  // Defaults: ON for Chair Rental, OFF for others (but owner can override)
  canSetOwnPrices Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, effectiveFrom])
  @@index([locationId])
}

// Snapshot stored on completed appointments (locks in compensation rates)
model CompensationSnapshot {
  id                String  @id @default(cuid())
  appointmentLineId String? @unique // Link to appointment line item
  transactionItemId String? @unique // Link to transaction item

  // Frozen values at time of service
  compensationType String
  commissionSplit  Decimal? @db.Decimal(5, 2)
  commissionBase   String?
  hourlyRate       Decimal? @db.Decimal(10, 2)

  createdAt DateTime @default(now())
}

// Many-to-many: Employee <-> Resource (chair assignments)
model UserResource {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  isDefault  Boolean  @default(false)

  createdAt DateTime @default(now())

  @@unique([userId, resourceId])
  @@index([userId])
  @@index([resourceId])
}

// Employee price overrides (for booth renters setting own prices)
model EmployeeServicePriceOverride {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation("PriceOverrides", fields: [userId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service @relation("EmployeePriceOverrides", fields: [serviceId], references: [id], onDelete: Cascade)

  price Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, serviceId])
  @@index([userId])
  @@index([serviceId])
}

// Barber allowed services (which services each barber can perform)
// Shop has master service menu, each barber has subset of services they can do
model BarberAllowedService {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation("AllowedServices", fields: [userId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service @relation("BarberAllowedServices", fields: [serviceId], references: [id], onDelete: Cascade)

  // Phase 2: Service availability schedule per barber
  // availableDays String? // e.g., "SAT,SUN" for weekends only

  createdAt DateTime @default(now())

  @@unique([userId, serviceId])
  @@index([userId])
  @@index([serviceId])
}

// ============ BRAND MODE MODELS (Phase 2) ============

model SubFranchisee {
  id String @id @default(cuid())

  // Link to brand (Franchisor)
  franchisorId String
  franchisor   Franchisor @relation(fields: [franchisorId], references: [id], onDelete: Cascade)

  // Operator info
  name  String
  email String  @unique
  phone String?

  // Assigned locations (Franchises that this sub-franchisee manages)
  franchises Franchise[]

  // Permission overrides (what brand allows them to edit)
  permissions String? // JSON string: { canEditPricing: false, canEditServices: false, ... }

  // Status
  status     String    @default("PENDING") // PENDING, ACTIVE, SUSPENDED
  invitedAt  DateTime  @default(now())
  acceptedAt DateTime?

  // Auth
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============ ANDROID POS SUPPORT ============

// Payment Log - Track payment attempts for dispute resolution
model PaymentLog {
  id            String  @id @default(cuid())
  transactionId String  @unique // Idempotency key from Android app
  status        String // SENT, APPROVED, DECLINED, UNKNOWN, ERROR, VOIDED, REFUNDED
  amount        Int? // Amount in cents
  authCode      String? // Authorization code from processor
  cardLast4     String? // Last 4 digits (masked)
  cardBrand     String? // VISA, MASTERCARD, AMEX, DISCOVER
  terminalId    String? // PAX terminal identifier
  reason        String? // Decline reason or error message

  // Relations
  stationId  String?
  station    Station?  @relation(fields: [stationId], references: [id])
  locationId String?
  location   Location? @relation("PaymentLogs", fields: [locationId], references: [id])
  userId     String?
  user       User?     @relation("PaymentLogs", fields: [userId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  @@index([status])
  @@index([locationId])
  @@index([createdAt])
}

// System Alert - For UNKNOWN payment states that need reconciliation
model SystemAlert {
  id       String @id @default(cuid())
  type     String // PAYMENT_RECONCILIATION, LOW_STOCK, etc.
  severity String // LOW, MEDIUM, HIGH, CRITICAL
  title    String
  message  String

  // Context
  locationId String?
  metadata   Json? // Additional context data

  // Status
  acknowledged   Boolean   @default(false)
  acknowledgedBy String?
  acknowledgedAt DateTime?
  resolved       Boolean   @default(false)
  resolvedBy     String?
  resolvedAt     DateTime?

  createdAt DateTime @default(now())

  @@index([type])
  @@index([severity])
  @@index([locationId])
  @@index([acknowledged])
}

// ============ SMS MARKETING + QUOTA SYSTEM ============

// SMS Usage Ledger - Append-only truth for billing proof
model SmsUsageLedger {
  id                String    @id @default(cuid())
  locationId        String
  campaignId        String? // Reference to DealCampaign
  customerId        String? // Reference to Client
  phone             String
  messageType       String // PROMO | TRANSACTIONAL
  messageContent    String? // Template snapshot for audit
  units             Int       @default(1) // SMS segments
  monthKey          String // "2026-01" in location timezone
  billCategory      String // FREE | OVERAGE
  providerMessageId String? // Provider's message ID
  status            String // QUEUED | SENT | DELIVERED | FAILED | OPTED_OUT | SUPPRESSED_*
  carrierCode       String? // Carrier response code
  suppressedReason  String? // NO_CONSENT | OPTED_OUT | FREQUENCY_CAP | DELIVERY_FAILURE | REDEEMED | RECENT_VISIT
  sentAt            DateTime?
  createdAt         DateTime  @default(now())

  location Location @relation("SmsUsageLogs", fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId, monthKey])
  @@index([campaignId])
  @@index([phone])
  @@index([status])
  @@index([createdAt])
}

// SMS Monthly Usage - Fast counters per location/month
model SmsMonthlyUsage {
  id               String   @id @default(cuid())
  locationId       String
  monthKey         String // "2026-01"
  freeUnitsUsed    Int      @default(0)
  overageUnitsUsed Int      @default(0)
  updatedAt        DateTime @updatedAt

  location Location @relation("SmsMonthlyUsage", fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, monthKey])
}

// SMS Opt-Out - Suppression list
model SmsOptOut {
  id        String   @id @default(cuid())
  phone     String   @unique
  reason    String // STOP | DELIVERY_FAILURE | SPAM_REPORT
  createdAt DateTime @default(now())

  @@index([phone])
}

// ============ DEAL SUGGESTIONS + CAMPAIGNS ============

// Deal Suggestion - Weekly generated suggestions
model DealSuggestion {
  id              String    @id @default(cuid())
  locationId      String
  weekOf          DateTime // Start of the week this suggestion is for
  dealType        String // SLOW_DAY | WIN_BACK | REBOOK
  title           String
  description     String
  discountType    String // FIXED_AMOUNT | PERCENTAGE | FREE_ADDON
  discountValue   Decimal
  priceFloor      Decimal? // Min final price (profit lock)
  minSpend        Decimal? // Min spend to qualify
  targetDays      String[] // ["MONDAY", "TUESDAY"]
  targetTimeStart String? // "10:00"
  targetTimeEnd   String? // "14:00"
  audienceCount   Int       @default(0) // Eligible customers
  status          String    @default("PENDING") // PENDING | SCHEDULED | SENT | EXPIRED
  scheduledFor    DateTime?
  sentAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  location  Location       @relation("DealSuggestions", fields: [locationId], references: [id], onDelete: Cascade)
  campaigns DealCampaign[]

  @@index([locationId, weekOf])
  @@index([status])
}

// Deal Campaign - Scheduled SMS campaign (linked to suggestion or standalone)
model DealCampaign {
  id               String    @id @default(cuid())
  locationId       String
  dealSuggestionId String? // Optional - may be custom campaign
  templateHash     String // Hash of content for duplicate detection
  audienceType     String // INACTIVE_35 | NEW_14 | VIP | ALL | CUSTOM
  audienceCount    Int       @default(0)
  estimatedUnits   Int       @default(0)
  estimatedFree    Int       @default(0)
  estimatedOverage Int       @default(0)
  actualUnits      Int?
  status           String    @default("DRAFT") // DRAFT | SCHEDULED | SENDING | SENT | BLOCKED
  blockedReason    String? // DUPLICATE_WITHIN_7_DAYS | FOOTER_MISSING | etc.
  scheduledFor     DateTime
  sentAt           DateTime?
  createdById      String

  // Message content
  messageTemplate String // SMS template with placeholders

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  location       Location        @relation("DealCampaigns", fields: [locationId], references: [id], onDelete: Cascade)
  dealSuggestion DealSuggestion? @relation(fields: [dealSuggestionId], references: [id], onDelete: SetNull)
  createdBy      User            @relation("DealCampaignsCreated", fields: [createdById], references: [id])

  @@index([locationId, status])
  @@index([locationId, scheduledFor])
  @@index([templateHash])
}

// ============ API CALL LOGGING (Cost & Performance Monitoring) ============
// Used to track API usage per location/device for optimization
// RETENTION: Raw logs 7-14 days, rollups 12-24 months

model ApiLog {
  id            String   @id @default(cuid())
  locationId    String?
  stationId     String?
  userId        String?
  route         String // API endpoint path
  method        String // GET, POST, PUT, DELETE
  status        Int // HTTP status code
  statusClass   String // "2xx", "4xx", "5xx"
  latencyMs     Int // Response time in milliseconds
  responseBytes Int? // Response body size in bytes
  userAgent     String?
  sampled       Boolean  @default(true) // false = skipped due to sampling
  createdAt     DateTime @default(now())

  @@index([locationId, createdAt])
  @@index([route, createdAt])
  @@index([createdAt])
}

// Daily aggregated API usage (rollup from ApiLog)
// Use this for dashboards, not raw ApiLog
model ApiUsageDaily {
  id         String   @id @default(cuid())
  date       DateTime @db.Date
  locationId String?
  route      String

  // Metrics
  totalCalls   Int    @default(0)
  successCalls Int    @default(0) // 2xx
  clientErrors Int    @default(0) // 4xx
  serverErrors Int    @default(0) // 5xx
  avgLatencyMs Int    @default(0)
  p95LatencyMs Int    @default(0)
  totalBytes   BigInt @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, locationId, route])
  @@index([locationId, date])
  @@index([date])
}

// ============ RMSC SCAN DATA IMPORT/EXPORT ============

model RmscImportBatch {
  id            String           @id @default(cuid())
  locationId    String
  location      Location         @relation(fields: [locationId], references: [id])
  fileName      String
  fileType      String // csv, xlsx
  fileHash      String
  importedById  String?
  importedAt    DateTime         @default(now())
  status        String           @default("COMPLETED") // PENDING, COMPLETED, PARTIAL, FAILED
  totalRows     Int              @default(0)
  importedRows  Int              @default(0)
  duplicateRows Int              @default(0)
  errorRows     Int              @default(0)
  errorSummary  Json?
  records       RmscScanRecord[]

  @@unique([locationId, fileHash])
  @@index([locationId, importedAt])
}

model RmscScanRecord {
  id            String          @id @default(cuid())
  importBatchId String
  importBatch   RmscImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  sourceRowNumber Int
  rowHash         String

  // Normalized analytics fields
  outletNumber       String?
  transactionDate    DateTime?
  basketId           String?
  scanId             String?
  registerNo         String?
  upc                String?
  productDescription String?
  quantity           Decimal?  @db.Decimal(10, 3)
  unitPrice          Decimal?  @db.Decimal(10, 2)
  extendedPrice      Decimal?  @db.Decimal(12, 2)
  manufacturerCode   String?
  manufacturerName   String?
  promoFlag          Boolean   @default(false)
  promoType          String?
  multipackFlag      Boolean   @default(false)
  buydownAmount      Decimal?  @db.Decimal(10, 2)
  loyaltyFlag        Boolean   @default(false)

  // Exact source preservation
  rawFields Json

  createdAt DateTime @default(now())

  @@unique([locationId, rowHash])
  @@index([locationId, transactionDate])
  @@index([locationId, manufacturerName])
  @@index([locationId, promoType])
  @@index([locationId, loyaltyFlag])
}

// ============ VENDOR INVOICE AUTO-IMPORT ============

model InboundFile {
  id             String          @id @default(cuid())
  franchiseId    String
  franchise      Franchise       @relation(fields: [franchiseId], references: [id])
  sourceType     String // "FTP" or "UPLOAD"
  filename       String
  remotePath     String?
  fileHash       String          @unique // SHA256 — prevents reprocessing
  fileSize       Int?
  parseStatus    String          @default("PENDING") // PENDING, PARSED, FAILED
  parseError     String?
  totalRows      Int             @default(0)
  parsedRows     Int             @default(0)
  matchedRows    Int             @default(0)
  newProductRows Int             @default(0)
  errorRows      Int             @default(0)
  errors         Json? // [{row, field, message}]
  invoices       VendorInvoice[]
  uploadedBy     String?
  startedAt      DateTime        @default(now())
  completedAt    DateTime?
  createdAt      DateTime        @default(now())

  @@index([franchiseId])
  @@index([fileHash])
  @@index([parseStatus])
}

model VendorInvoice {
  id            String       @id @default(cuid())
  franchiseId   String
  franchise     Franchise    @relation(fields: [franchiseId], references: [id])
  locationId    String?
  location      Location?    @relation(fields: [locationId], references: [id])
  supplierId    String?
  supplier      Supplier?    @relation(fields: [supplierId], references: [id])
  inboundFileId String?
  inboundFile   InboundFile? @relation(fields: [inboundFileId], references: [id])

  // Header (all from CSV)
  invoiceNumber    String
  invoiceType      String    @default("INVOICE") // INVOICE, CREDIT, RETURN
  vendorName       String
  vendorStoreNum   String?
  retailerStoreNum String?
  retailerVendorId String?
  invoiceDate      DateTime
  dueDate          DateTime?
  processDate      DateTime?
  totalAmount      Decimal   @db.Decimal(12, 2)
  itemCount        Int
  poNumber         String?
  poDate           DateTime?
  refInvoiceNumber String?

  // Lifecycle — never delete, only transition
  status         String   @default("IMPORTED")
  // IMPORTED → REVIEW_REQUIRED → READY_TO_POST → POSTED → VOIDED
  matchRate      Decimal? @db.Decimal(5, 2)
  totalItems     Int      @default(0)
  matchedItems   Int      @default(0)
  newItems       Int      @default(0)
  errorItems     Int      @default(0)
  costAlertItems Int      @default(0)

  // Reconciliation
  parsedTotal   Decimal? @db.Decimal(12, 2) // Sum of line extendedPrice
  discrepancy   Decimal? @db.Decimal(12, 2) // parsedTotal − totalAmount
  discrepancyOk Boolean  @default(false)

  // Posting
  postedAt   DateTime?
  postedBy   String?
  voidedAt   DateTime?
  voidedBy   String?
  voidReason String?

  items      VendorInvoiceItem[]
  uploadedBy String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@unique([supplierId, locationId, invoiceNumber, invoiceDate])
  @@index([franchiseId])
  @@index([status])
  @@index([vendorName])
  @@index([inboundFileId])
}

model VendorInvoiceItem {
  id        String        @id @default(cuid())
  invoiceId String
  invoice   VendorInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  // Raw CSV data (all 33 fields preserved)
  lineNumber       Int
  vendorProductNum String?
  quantity         Int
  unitCost         Decimal @db.Decimal(12, 4)
  unitOfMeasure    String? // CA, BO, EA, CS
  productVolume    String?
  caseUpc          String?
  cleanUpc         String?
  packUpc          String?
  productDesc      String
  productClass     String? // Wine, Spirits, Beer
  glCode           String?
  packsPerCase     Int?
  unitsPerPack     Int?

  // Adjustments
  discountAdj   Decimal @default(0) @db.Decimal(12, 2)
  depositAdj    Decimal @default(0) @db.Decimal(12, 2)
  miscAdj       Decimal @default(0) @db.Decimal(12, 2)
  taxAdj        Decimal @default(0) @db.Decimal(12, 2)
  deliveryAdj   Decimal @default(0) @db.Decimal(12, 2)
  extendedPrice Decimal @db.Decimal(12, 2)

  // Computed
  baseUnitsReceived Int? // Converted to sellable units
  perUnitCost       Decimal? @db.Decimal(12, 4) // Cost per single sellable unit

  // Match result
  matchStatus          String  @default("PENDING")
  // PENDING, MATCHED, NEW_PRODUCT, SUGGESTED, MANUAL, ERROR
  matchMethod          String? // SUPPLIER_SKU, CLEAN_UPC, CASE_UPC, PACK_UPC, LEGACY_BARCODE, MANUAL
  matchedProductId     String?
  autoCreatedProductId String?
  suggestedProductIds  Json? // Top 3 candidates for review

  // Cost tracking
  costChanged   Boolean  @default(false)
  previousCost  Decimal? @db.Decimal(12, 4)
  costChangePct Decimal? @db.Decimal(8, 2)

  createdAt DateTime @default(now())

  @@index([invoiceId])
  @@index([cleanUpc])
  @@index([matchStatus])
}

model ProductBarcodeAlias {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  barcode   String   @unique
  type      String // CLEAN, CASE, PACK, ALT, MANUAL
  isPrimary Boolean  @default(false)
  source    String? // INVOICE_IMPORT, MANUAL, SCAN
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([barcode])
}

model ProductCostHistory {
  id         String    @id @default(cuid())
  productId  String
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])
  oldCost    Decimal   @db.Decimal(12, 4)
  newCost    Decimal   @db.Decimal(12, 4)
  changePct  Decimal   @db.Decimal(8, 2)
  sourceType String // VENDOR_INVOICE, MANUAL
  sourceId   String? // invoiceItemId
  changedBy  String?
  changedAt  DateTime  @default(now())

  @@index([productId])
  @@index([changedAt])
}

model FtpConfig {
  id            String    @id @default(cuid())
  franchiseId   String    @unique
  franchise     Franchise @relation(fields: [franchiseId], references: [id])
  host          String
  port          Int       @default(21)
  protocol      String    @default("SFTP") // FTP, FTPS, SFTP
  username      String
  password      String // Should be encrypted at app layer
  remotePath    String    @default("/")
  filePattern   String    @default("*.csv")
  autoFetch     Boolean   @default(false)
  fetchSchedule String    @default("0 6 * * *")
  lastFetchAt   DateTime?
  costAlertPct  Decimal   @default(10) @db.Decimal(5, 2) // Configurable threshold
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ═══════════════════════════════════════════════════════════════════════════
// OWNER OPERATING SYSTEM — Intelligence Engine
// Pipeline: Signal Collectors → OwnerSignal → OwnerIssue → Delivery
// ═══════════════════════════════════════════════════════════════════════════

// ──── Enums ────

enum OwnerSignalType {
  CASH_VARIANCE
  DEPOSIT_OVERDUE
  VOID_SPIKE
  REFUND_SPIKE
  LOW_STOCK_CRITICAL
  SALES_DROP
  ID_CHECK_MISSED
  EMPLOYEE_RISK_HIGH
  DEVICE_OFFLINE
  TRANSFER_DISCREPANCY
}

enum OwnerIssueCategory {
  CASH
  INVENTORY
  SALES
  COMPLIANCE
  EMPLOYEE
  OPERATIONS
}

enum OwnerIssueSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum OwnerIssueStatus {
  OPEN
  ACKNOWLEDGED
  ASSIGNED
  SNOOZED
  RESOLVED
  ESCALATED
  REOPENED
}

enum OwnerIssueEventType {
  CREATED
  ACKNOWLEDGED
  ASSIGNED
  SNOOZED
  RESOLVED
  ESCALATED
  NOTE_ADDED
  REOPENED
  PRIORITY_CHANGED
  DUE_CHANGED
}

enum OwnerIssueResolvedReason {
  ROOT_CAUSE_FIXED
  FALSE_POSITIVE
  DUPLICATE
  WONT_FIX
}

enum OwnerSignalEntityType {
  USER
  SKU
  DRAWER
  SHIFT
  DEVICE
  DEPOSIT
}

enum OwnerIssueSourceType {
  OWNER_SIGNAL
  STORE_EXCEPTION
  SYSTEM_ALERT
  COMPUTED
}

enum OwnerDigestType {
  MORNING
  DAILY_RECAP
  WEEKLY
  CRITICAL_ALERT
}

enum OwnerDigestChannel {
  DASHBOARD
  EMAIL
  SMS
}

enum OwnerDigestStatus {
  QUEUED
  SENT
  FAILED
  DELIVERED
  OPENED
}

enum OwnerRecommendationScope {
  OWNER
  DELEGATABLE
  AUTO_CANDIDATE
}

// ──── Stage 1: Raw Signals ────

model OwnerSignal {
  id          String                 @id @default(cuid())
  franchiseId String
  locationId  String
  signalType  OwnerSignalType
  entityType  OwnerSignalEntityType?
  entityId    String?
  signalDate  DateTime // Business date (not wall-clock)
  payload     Json? // Full context from source module
  scoreInputs Json? // Pre-computed: {financialImpact, urgency, ...}
  dedupKey    String? // Formula output per signal type
  processed   Boolean                @default(false)
  processedAt DateTime?
  jobRunId    String? // Idempotency: which cron run created this
  createdAt   DateTime               @default(now())

  @@index([franchiseId, signalType, signalDate])
  @@index([franchiseId, processed, createdAt])
  @@index([dedupKey])
  @@index([jobRunId])
}

// ──── Stage 2: Issues (Central queue) ────

model OwnerIssue {
  id          String   @id @default(cuid())
  franchiseId String
  locationId  String
  location    Location @relation(fields: [locationId], references: [id])

  // Classification
  category  OwnerIssueCategory
  issueType OwnerSignalType
  severity  OwnerIssueSeverity @default(MEDIUM)

  // Dedup
  dedupKey       String?
  isActiveSignal Boolean @default(true)
  repeatCount    Int     @default(1)
  reopenedCount  Int     @default(0)

  // Scoring
  priorityScore   Float @default(0)
  financialImpact Float @default(0)
  urgencyScore    Float @default(0)
  complianceRisk  Float @default(0)

  // Content
  title       String
  summary     String // Human-readable: "Store 3 cash drawer short $47.50"
  details     Json?
  reasoning   String? // "High because deposit 2 days overdue + open cash variance"
  recommended String? // "Verify deposit slip"

  // Status + concurrency
  status  OwnerIssueStatus @default(OPEN)
  version Int              @default(1)

  // Action tracking
  assignedToId     String?
  assignedToName   String?
  assignedAt       DateTime?
  dueAt            DateTime?
  snoozedUntil     DateTime?
  acknowledgedById String?
  acknowledgedAt   DateTime?
  resolvedById     String?
  resolvedAt       DateTime?
  resolutionNote   String?
  resolvedReason   OwnerIssueResolvedReason?

  // Dual resolution
  workflowResolvedAt DateTime? // User clicked resolve
  sourceResolvedAt   DateTime? // Engine confirmed signal gone

  escalatedAt   DateTime?
  escalatedToId String?

  // Timestamps
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  // Source
  sourceType OwnerIssueSourceType?
  sourceId   String?

  events OwnerIssueEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([franchiseId, status])
  @@index([franchiseId, status, severity])
  @@index([franchiseId, assignedToId, status])
  @@index([locationId, status])
  @@index([dedupKey])
  @@index([franchiseId, issueType, status])
  @@index([priorityScore])
  @@index([dueAt])
  @@index([status, snoozedUntil])
}

// ──── Audit Trail ────

model OwnerIssueEvent {
  id           String              @id @default(cuid())
  ownerIssueId String
  issue        OwnerIssue          @relation(fields: [ownerIssueId], references: [id], onDelete: Cascade)
  eventType    OwnerIssueEventType
  fromStatus   OwnerIssueStatus?
  toStatus     OwnerIssueStatus?
  actorUserId  String?
  actorName    String?
  note         String?
  meta         Json? // {oldDueAt, newDueAt, oldAssignee, newAssignee, ...}
  createdAt    DateTime            @default(now())

  @@index([ownerIssueId, createdAt])
}

// ──── Store Health ────

model StoreHealthScore {
  id               String   @id @default(cuid())
  locationId       String
  franchiseId      String
  date             DateTime @db.Date
  salesHealth      Int      @default(50)
  cashHealth       Int      @default(50)
  laborHealth      Int      @default(50)
  inventoryHealth  Int      @default(50)
  complianceHealth Int      @default(50)
  lpHealth         Int      @default(50)
  overallScore     Int      @default(50)
  overallStatus    String   @default("GREEN")
  scoreVersion     String?
  weightsUsed      Json?
  rawMetrics       Json?
  factors          Json?
  createdAt        DateTime @default(now())

  @@unique([locationId, date])
  @@index([franchiseId, date])
  @@index([overallStatus])
}

// ──── Manager Accountability ────

model ManagerScorecard {
  id               String   @id @default(cuid())
  userId           String
  locationId       String
  franchiseId      String
  period           String // "2026-03" or "2026-W11"
  avgCloseTime     Float?
  alertResponseMin Float?
  issuesIgnored    Int      @default(0)
  cashVarianceRate Float?
  voidApprovalRate Float?
  lowStockDays     Int      @default(0)
  overallGrade     String   @default("B")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, period])
  @@index([franchiseId, period])
  @@index([locationId])
}

// ──── Digest Delivery ────

model OwnerDigest {
  id            String             @id @default(cuid())
  userId        String
  franchiseId   String
  digestType    OwnerDigestType
  channel       OwnerDigestChannel
  businessDate  DateTime           @db.Date
  issueCount    Int
  topIssues     Json
  storeScores   Json
  recommended   Json?
  status        OwnerDigestStatus  @default(QUEUED)
  failureReason String?
  externalId    String?
  jobRunId      String?
  deliveredAt   DateTime           @default(now())
  openedAt      DateTime?

  @@unique([userId, digestType, channel, businessDate])
  @@index([userId, digestType])
  @@index([franchiseId])
  @@index([status])
}

// ──── Notification Preferences ────

model OwnerNotificationPreference {
  id                     String   @id @default(cuid())
  userId                 String
  franchiseId            String
  morningEmailEnabled    Boolean  @default(true)
  morningEmailTime       String? // "06:30" in owner timezone
  dailyRecapEnabled      Boolean  @default(true)
  weeklyDigestEnabled    Boolean  @default(true)
  criticalSmsEnabled     Boolean  @default(true)
  depositSmsEnabled      Boolean  @default(true)
  complianceSmsEnabled   Boolean  @default(true)
  cashVarianceSmsEnabled Boolean  @default(false)
  quietHoursStart        String? // "22:00"
  quietHoursEnd          String? // "06:00"
  weekendEnabled         Boolean  @default(true)
  weightOverrides        Json? // {DEPOSIT_OVERDUE: 95, SALES_DROP: 40}
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@unique([userId, franchiseId])
}

// ============ ONLINE BOOKING: PER-LOCATION PROFILE ============
// Auto-created for SERVICE businesses during onboarding.
// Controls publish state, booking rules, branding, and setup wizard progress.

model BookingProfile {
  id         String   @id @default(cuid())
  locationId String   @unique
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  // Publish state — booking page is DRAFT until owner explicitly publishes
  isPublished Boolean   @default(false)
  publishedAt DateTime?

  // Booking rules
  maxAdvanceDays   Int @default(30) // How far ahead customers can book
  minNoticeMinutes Int @default(120) // Minimum notice before appointment (2 hours default)
  slotIntervalMin  Int @default(30) // Time slot granularity in minutes
  bufferMinutes    Int @default(0) // Buffer between consecutive appointments

  // Branding
  accentColor    String  @default("#7C3AED") // Violet default
  welcomeMessage String?

  // Setup wizard tracking
  setupCompleted Boolean @default(false)
  setupStep      String  @default("services") // services, staff, hours, rules, publish

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isPublished])
}

// ============ ORO 9 STOREFRONT ============

model StorefrontProfile {
  id         String   @id @default(cuid())
  locationId String   @unique
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  // Master toggle
  isEnabled Boolean @default(false)

  // Display
  headline       String? // "Welcome to Mike's Corner Store"
  bannerImageUrl String? // Hero banner

  // Product Visibility
  showAllCategories  Boolean @default(true) // false = use visibleCategoryIds
  visibleCategoryIds String? // JSON: ["catId1","catId2"]
  hiddenItemIds      String? // JSON: ["itemId1","itemId2"]
  hideOutOfStock     Boolean @default(true)

  // Pickup Rules
  pickupEnabled     Boolean @default(true)
  pickupLeadMinutes Int     @default(30) // "Ready in ~30 min"
  maxOrdersPerSlot  Int     @default(10)

  // Order Rules
  minOrderAmount    Decimal? @db.Decimal(12, 2)
  maxItemsPerOrder  Int      @default(50)
  orderNotesEnabled Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StorefrontOrder {
  id          String   @id @default(cuid())
  orderNumber String   @unique // "SF-1001"
  locationId  String
  location    Location @relation(fields: [locationId], references: [id])

  // Customer (no account required)
  customerName  String
  customerPhone String

  // Line items
  items StorefrontOrderItem[]

  // Totals (estimated — final price determined at POS)
  subtotal       Decimal @db.Decimal(12, 2)
  estimatedTax   Decimal @default(0) @db.Decimal(12, 2)
  estimatedTotal Decimal @db.Decimal(12, 2)
  notes          String?

  // PENDING → CONFIRMED → READY → PICKED_UP
  // PENDING → CANCELLED
  status String @default("PENDING")

  // Pickup
  pickupTime DateTime? // Requested
  readyAt    DateTime? // Merchant marks ready
  pickedUpAt DateTime? // Customer arrives

  // POS linkage — set ONLY when converted at register
  transactionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId])
  @@index([status])
  @@index([orderNumber])
}

model StorefrontOrderItem {
  id      String          @id @default(cuid())
  orderId String
  order   StorefrontOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  itemId   String // Reference to Item (snapshot, not FK)
  itemName String // Snapshot at order time
  quantity Int
  price    Decimal @db.Decimal(12, 2) // Snapshot at order time
  total    Decimal @db.Decimal(12, 2)

  @@index([orderId])
}

// ============ EMAIL (SES DUAL-LANE) ============

model EmailEvent {
  id             String   @id @default(cuid())
  messageId      String   @unique // SES Message ID
  lane           String // TRANSACTIONAL | MARKETING
  recipientEmail String
  template       String? // receipt, gift_card, password_reset, campaign, etc.
  status         String   @default("SENT") // SENT | DELIVERED | OPENED | CLICKED | BOUNCED | COMPLAINED
  franchiseId    String?
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([franchiseId])
  @@index([lane])
  @@index([status])
  @@index([recipientEmail])
  @@index([createdAt])
}

model EmailSuppression {
  id        String   @id @default(cuid())
  email     String   @unique // Suppressed email address
  reason    String // BOUNCE | COMPLAINT | UNSUBSCRIBE
  lane      String   @default("MARKETING") // MARKETING (only marketing blocked) | ALL (all blocked)
  createdAt DateTime @default(now())

  @@index([lane])
}

// ==========================================
// SALON LOYALTY V1 (BEAUTY LOOP ENGINE)
// ==========================================

model SalonLoyaltyProgram {
  id            String  @id @default(cuid())
  franchisorId  String?
  franchiseId   String?
  locationId    String?
  name          String
  code          String  @unique
  customerLabel String?
  description   String?

  status      String  @default("DRAFT") // DRAFT, ACTIVE, PAUSED, ARCHIVED
  programType String  @default("SERVICE_PUNCH") // SERVICE_PUNCH, BEAUTY_LOOP
  goal        String? // REPEAT_VISITS, REBOOKING, SIGNATURE_SERVICE, etc.

  punchesRequired Int?
  earnMode        String   @default("ONE_PER_QUALIFYING_VISIT")
  rewardType      String // FREE_SERVICE, PERCENT_OFF, FIXED_OFF, FREE_ADDON
  rewardValue     Decimal? @db.Decimal(10, 2)
  rewardPercent   Decimal? @db.Decimal(5, 2)

  appliesToSameLocationOnly Boolean @default(true)
  allowMultiLocationEarn    Boolean @default(false)
  allowMultiLocationRedeem  Boolean @default(false)

  autoEnroll                Boolean @default(true)
  requireIdentifiedCustomer Boolean @default(true)

  timingWindowDays Int? // Beauty Loop behavior
  rewardExpiryDays Int?

  stackWithDiscounts         Boolean @default(false)
  reverseOnRefund            Boolean @default(true)
  reverseOnVoid              Boolean @default(true)
  managerApprovalForOverride Boolean @default(false)

  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  rules        SalonLoyaltyProgramRule[]
  memberships  SalonCustomerLoyaltyMembership[]
  transactions SalonLoyaltyLedgerEntry[]

  @@index([franchisorId])
  @@index([franchiseId])
  @@index([locationId])
  @@index([status])
  @@index([programType])
}

model SalonLoyaltyProgramRule {
  id               String   @id @default(cuid())
  loyaltyProgramId String
  serviceId        String?
  categoryId       String?
  excluded         Boolean  @default(false)
  minSubtotal      Decimal? @db.Decimal(10, 2)
  locationId       String?
  stylistId        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  loyaltyProgram SalonLoyaltyProgram @relation(fields: [loyaltyProgramId], references: [id], onDelete: Cascade)
}

model SalonCustomerLoyaltyMembership {
  id               String  @id @default(cuid())
  loyaltyProgramId String
  clientId         String
  homeLocationId   String?
  status           String  @default("ACTIVE") // ACTIVE, PAUSED, COMPLETED, EXPIRED

  punchesEarned        Int       @default(0)
  rewardsUnlocked      Int       @default(0)
  rewardsRedeemed      Int       @default(0)
  streakPreservedUntil DateTime?
  rewardExpiresAt      DateTime?
  lastQualifiedVisitAt DateTime?
  lastRewardRedeemedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  loyaltyProgram SalonLoyaltyProgram @relation(fields: [loyaltyProgramId], references: [id], onDelete: Cascade)
  client         Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, loyaltyProgramId])
  @@index([clientId, loyaltyProgramId])
  @@index([status, rewardExpiresAt])
  @@index([homeLocationId, status])
}

model SalonLoyaltyLedgerEntry {
  id                        String   @id @default(cuid())
  loyaltyProgramId          String
  membershipId              String
  clientId                  String
  transactionId             String?
  locationId                String?
  stylistId                 String?
  entryType                 String // EARN, REVERSE_REFUND, REVERSE_VOID, REWARD_UNLOCK, REDEEM, EXPIRE, MANUAL_ADJUST
  idempotencyKey            String   @unique // Rigid anchor: '{programId}_{membershipId}_{entryType}_{transactionId}_{sourceRefundId|base}'
  punchesDelta              Int      @default(0)
  rewardDelta               Int      @default(0)
  notes                     String?
  sourceRefundTransactionId String? // Tie reversal uniquely to the refund event 
  transactionLineItemId     String? // Track EXACTLY which line was credited
  createdByUserId           String?
  createdAt                 DateTime @default(now())

  loyaltyProgram          SalonLoyaltyProgram @relation(fields: [loyaltyProgramId], references: [id], onDelete: Cascade)
  transaction             Transaction?        @relation("LoyaltyEntries", fields: [transactionId], references: [id])
  sourceRefundTransaction Transaction?        @relation("LoyaltyReversals", fields: [sourceRefundTransactionId], references: [id])

  @@index([membershipId])
  @@index([transactionId])
  @@index([sourceRefundTransactionId])
  @@index([entryType])
  @@index([createdAt])
  @@index([clientId, loyaltyProgramId, createdAt])
}

model SalonTransactionLoyaltyRedemption {
  id                    String   @id @default(cuid())
  transactionId         String
  transactionLineItemId String? // Precise link to what line was comped
  loyaltyProgramId      String
  membershipId          String
  rewardType            String
  rewardValue           Decimal? @db.Decimal(10, 2)
  createdAt             DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([membershipId])
  @@index([loyaltyProgramId])
}
